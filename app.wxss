page, view, text, input, button, textarea, image, scroll-view {
  box-sizing: border-box;
}

page {
  --paper:    #F2EEDF;
  --ink:      #2A241B;
  --ink-soft: #5C5345;
  --pink:     #E07A5F;
  --lemon:    #F2CC8F;
  --blush:    #E6B89C;
  --sage:     #81B29A;
  --lilac:    #9A8FB5;
  --muted:    #8C8275;
  --border:   #D9D4C7;
  background: var(--paper);
  font-family: -apple-system, 'Noto Sans SC', 'PingFang SC', sans-serif;
  color: var(--ink);
  font-size: 28rpx;
  max-width: 750rpx;
  margin: 0 auto;
  padding-bottom: 120rpx;
  overflow-x: hidden;
}

.container { padding: 20rpx 28rpx; overflow-x: hidden; box-sizing: border-box; width: 100%; }
.card {
  background: #fff; border-radius: 20rpx; padding: 32rpx;
  margin-bottom: 28rpx; border: 1rpx solid var(--border);
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); position: relative;
}
.card-label {
  font-size: 22rpx; color: var(--sage); letter-spacing: 0.12em;
  margin-bottom: 16rpx; display: flex; align-items: center; gap: 12rpx;
}
.tone-dot {
  width: 12rpx; height: 12rpx; border-radius: 2rpx; margin-left: auto;
  transform: rotate(45deg);
}

.theme-text {
  font-family: 'Noto Serif SC', 'Songti SC', serif;
  font-size: 36rpx; font-weight: 700; margin-bottom: 20rpx; line-height: 1.35;
}
.excerpt {
  font-size: 28rpx; line-height: 1.7; padding-left: 20rpx;
  border-left: 4rpx solid rgba(42,36,27,0.1); margin-bottom: 14rpx;
}
.src-badge {
  font-size: 20rpx; color: var(--muted); display: block; margin-bottom: 4rpx;
}

.frag-badge { font-weight: 700; margin-right: 8rpx; }
.frag-badge.ai { color: var(--lilac); }
.frag-badge.self { color: var(--sage); }

.tl-item { display: flex; gap: 16rpx; padding: 16rpx 0; border-bottom: 1rpx solid var(--border); align-items: flex-start; }
.tl-dot { width: 14rpx; height: 14rpx; border-radius: 50%; margin-top: 8rpx; flex-shrink: 0; }
.tl-dot.ai { background: var(--lilac); }
.tl-dot.self { background: var(--sage); }
.tl-body { flex: 1; font-size: 26rpx; line-height: 1.6; color: var(--ink); word-break: break-word; overflow-wrap: break-word; min-width: 0; }
.tl-time { font-size: 20rpx; color: var(--muted); white-space: nowrap; min-width: 80rpx; text-align: right; }
.tl-play {
  font-size: 22rpx; color: var(--pink); padding: 4rpx 12rpx;
  border: 1rpx solid var(--border); border-radius: 16rpx; flex-shrink: 0;
}

.btn {
  display: inline-flex; align-items: center; justify-content: center;
  padding: 16rpx 36rpx; border-radius: 32rpx; font-size: 28rpx;
  border: 1rpx solid var(--border); background: transparent; color: var(--ink-soft);
  transition: all 0.15s;
}
.btn-primary { background: var(--ink); color: var(--paper); border-color: var(--ink); font-weight: 600; }
.btn-sage { background: var(--sage); color: var(--ink); border-color: var(--sage); }

.btn-row { display: flex; gap: 14rpx; flex-wrap: wrap; margin-top: 20rpx; }

.voice-area { display: flex; align-items: center; gap: 28rpx; padding: 20rpx 0; }
.vinyl-disc {
  width: 120rpx; height: 120rpx; border-radius: 50%; flex-shrink: 0;
  background: radial-gradient(circle at center, #d0ccc0 0rpx, #d0ccc0 2rpx, #e8e4d8 2rpx, #e8e4d8 8rpx, #d0ccc0 8rpx, #d0ccc0 10rpx, #e8e4d8 10rpx, #e8e4d8 14rpx, #d0ccc0 14rpx);
  box-shadow: 0 0 0 4rpx #c4bfb0, 0 0 0 10rpx #e8e4d8, 0 0 0 12rpx #c4bfb0, 0 8rpx 32rpx rgba(0,0,0,0.1);
  display: flex; align-items: center; justify-content: center; position: relative;
}
.vinyl-disc::after {
  content: 'REC'; font-size: 20rpx; font-weight: 700; color: #fff;
  width: 60rpx; height: 60rpx; border-radius: 50%; background: var(--pink);
  display: flex; align-items: center; justify-content: center;
}
.vinyl-disc.recording { animation: spin 3s linear infinite; }
.vinyl-disc.recording::after { content: '■'; font-size: 28rpx; }
@keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }

.voice-status { font-size: 26rpx; color: var(--pink); min-height: 40rpx; padding: 10rpx 0; font-style: italic; }

.mic-label { font-size: 30rpx; color: var(--text); }
.mic-sublabel { font-size: 22rpx; color: var(--muted); }

.text-input { width: 100%; min-height: 160rpx; padding: 20rpx; border-radius: 16rpx; border: 1rpx solid var(--border); background: #fff; font-size: 28rpx; line-height: 1.7; }

.day-nav { display: flex; align-items: center; justify-content: center; gap: 28rpx; padding: 16rpx 0 28rpx; }
.day-nav button { width: 64rpx; height: 64rpx; border-radius: 50%; border: 1rpx solid var(--border); background: #fff; font-size: 36rpx; display: flex; align-items: center; justify-content: center; }
.nav-date { font-size: 30rpx; color: var(--ink-soft); min-width: 200rpx; text-align: center; }

.empty { text-align: center; padding: 100rpx 40rpx; color: var(--muted); }
.empty .icon { font-size: 64rpx; margin-bottom: 20rpx; }
.empty .main { font-size: 34rpx; color: var(--ink); margin-bottom: 12rpx; }
.empty .sub { font-size: 26rpx; line-height: 1.7; }

.gen-steps { display: flex; gap: 14rpx; flex-wrap: wrap; justify-content: center; margin-top: 20rpx; }
.gen-step { padding: 14rpx 28rpx; border-radius: 28rpx; background: rgba(42,36,27,0.04); font-size: 26rpx; color: var(--muted); transition: all 0.3s; }
.gen-step.active { background: var(--sage); color: #fff; }
.gen-step.done { background: rgba(129,178,154,0.2); color: var(--ink); }

.drawer-mask { position: fixed; inset: 0; z-index: 100; background: rgba(0,0,0,0.4); }
.drawer { position: fixed; right: 0; top: 0; bottom: 0; z-index: 101; width: 600rpx; background: var(--paper); padding: 40rpx 36rpx; box-shadow: -6rpx 0 30rpx rgba(0,0,0,0.12); }
.drawer-title { font-size: 34rpx; margin-bottom: 32rpx; display: flex; justify-content: space-between; }
.drawer-input { width: 100%; padding: 18rpx 24rpx; border-radius: 14rpx; border: 1rpx solid var(--border); background: #fff; font-size: 28rpx; margin-bottom: 28rpx; }
.drawer-info { background: #fff; border-radius: 16rpx; padding: 24rpx; font-size: 26rpx; line-height: 2; }

/* ---- Dual Cards ---- */
.summary-card { border-left: 4rpx solid var(--sage); }
.refraction-card { border-left: 4rpx solid var(--lilac); }
.overview-text {
  font-size: 28rpx; line-height: 1.7; color: var(--ink-soft);
  margin-bottom: 20rpx; padding: 16rpx 20rpx;
  background: rgba(242,238,223,0.6); border-radius: 12rpx;
}
.insight-text { font-size: 28rpx; line-height: 1.7; color: var(--ink); margin-bottom: 16rpx; }
.card-divider {
  display: flex; align-items: center; gap: 16rpx; margin: 8rpx 0; padding: 0 8rpx;
}
.divider-line { flex: 1; height: 1rpx; background: var(--border); }
.divider-label { font-size: 20rpx; color: var(--lilac); letter-spacing: 0.12em; white-space: nowrap; }
.mirror-note {
  display: flex; align-items: flex-start; gap: 8rpx;
  font-size: 22rpx; color: var(--muted); line-height: 1.6;
  padding: 12rpx 16rpx; margin-bottom: 16rpx;
  background: rgba(154,143,181,0.06); border-radius: 10rpx;
}
.mirror-icon { color: var(--lilac); flex-shrink: 0; margin-top: 2rpx; }
.card-section { margin: 20rpx 0 32rpx; }
